# Copy to .env.local for local development. Do not commit .env.local.
# Vercel/production: Project → Settings → Environment Variables → Redeploy.
# Never prefix database variables with NEXT_PUBLIC_.

DB_SERVER=your_sql_server_ip_or_host
DB_DATABASE=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_PORT=1433
DB_ENCRYPT=false

# Optional aliases (instead of DB_SERVER / DB_DATABASE):
# DB_HOST=
# DB_NAME=
