# Copy this file to .env.local and set the real password there.
# Do not commit .env.local.
#
# Dev only — comma-separated extra IPs/hostnames for webpack HMR (merged with localhost/127.0.0.1).
# Example: NEXT_DEV_ALLOWED_ORIGINS=10.81.234.2,192.168.1.10
#
DB_SERVER=95.217.203.20
DB_DATABASE=_rifiiorg_db
DB_USER=rifiiorg
DB_PASSWORD=USE_THE_PASSWORD_FROM_VERCEL_ENV
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Required for signing httpOnly JWT session cookies.
# Generate a strong random value for production.
AUTH_SECRET=change-this-to-a-long-random-secret

# Incident image uploads. UPLOAD_DIR must be writable by the Node.js process
# and mapped by the web server to BASE_URL/NC_IR_Upload.
UPLOAD_DIR=/httpdocs/NC_IR_Upload
BASE_URL=https://rif-ii.org
